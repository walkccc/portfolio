<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ site.author }}</title>
    <link rel="stylesheet" href="tailwind.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600;700&family=Jost:wght@100;200;300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://unpkg.com/boxicons@2.1.2/css/boxicons.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-themeBlack h-screen p-4 font-fira">
    <!-- container -->
    <div
      class="bg-themeBlack flex flex-col h-full rounded-lg border border-themeLine"
    >
      <!-- navbar -->
      <div
        class="flex justify-between items-center h-14 p-4 text-themeGray border-b border-themeLine"
      >
        <h3>pengyu-chen</h3>
        <div class="hidden">
          <i class="bx bx-menu text-3xl"></i>
        </div>
        <div class="pt-2">
          <i class="bx bx-x text-3xl"></i>
        </div>
      </div>
      <!-- main body -->
      <div class="h-full hidden">
        <!-- hero -->
        <div class="flex flex-col justify-between mt-24 h-3/4 p-6">
          <div>
            <h3 class="text-lg leading-6 text-themeWhite pl-1 mb-2">
              Hi all. I am
            </h3>
            <h6 class="text-6xl text-themeWhite">Peng-Yu</h6>
            <h6 class="text-6xl text-themeWhite">Chen</h6>
            <h3 class="text-lg text-themeGreen pl-1">> Software Engineer</h3>
          </div>

          <div class="text-sm space-y-4">
            <h3 class="text-themeGray">// find my profile on GitHub:</h3>
            <h3>
              <span class="text-themeBlue">const string</span>
              <span class="text-themeGreen">githubLink</span>
              <span class="text-themeWhite">=</span>
              <span class="text-themeRed">https://github.com/walkccc";</span>
            </h3>
          </div>
        </div>
        <!-- END hero -->
      </div>
      <!-- END main body -->
      <!-- sidebar menu -->
      <div class="flex flex-col justify-between h-full font-light leading-5">
        <div>
          <div
            class="h-14 p-4 flex items-center text-themeWhite border-b border-themeLine"
          >
            <h3>hello</h3>
          </div>
          <div
            class="h-14 p-4 flex items-center text-themeWhite border-b border-themeLine"
          >
            <h3>about-me</h3>
          </div>
          <div
            class="h-14 p-4 flex items-center text-themeWhite border-b border-themeLine"
          >
            <h3>experience</h3>
          </div>
          <div
            class="h-14 p-4 flex items-center text-themeWhite border-b border-themeLine"
          >
            <h3>education</h3>
          </div>
        </div>
        <div
          class="h-12 flex justify-between items-center text-themeGray border-t border-themeLine"
        >
          <h3 class="p-4 text-base font-normal leading-5">find me in:</h3>
          <div class="w-5/12 h-full flex">
            <div class="w-1/3">
              <i
                class="bx bxl-github p-3 text-2xl border-l border-themeLine"
              ></i>
            </div>
            <div class="w-1/3">
              <i
                class="bx bxl-linkedin p-3 text-2xl border-l border-themeLine"
              ></i>
            </div>
            <div class="w-1/3">
              <i
                class="bx bxl-twitter p-3 text-2xl border-l border-themeLine"
              ></i>
            </div>
          </div>
        </div>
      </div>
      <!-- END sidebar menu -->
    </div>
    <!-- END container -->
  </body>
</html>
